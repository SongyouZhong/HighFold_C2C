# ============================================================
# HighFold-C2C Service Configuration
# ============================================================
# Copy this file to .env and set values for your environment.
#
# This service connects to EXTERNAL PostgreSQL and SeaweedFS
# instances already running on the host machine.
# When running inside Docker, use host.docker.internal to
# reach host services.

# ── Database (external PostgreSQL on host) ───────────────────
# For Docker deployment, use host.docker.internal
# For local (non-Docker) deployment, use 127.0.0.1
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=secret
DB_NAME=mydatabase
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── SeaweedFS Object Storage (external on host) ─────────────
# For Docker deployment, use host.docker.internal
# For local (non-Docker) deployment, use localhost
SEAWEED_API_TYPE=filer
SEAWEED_FILER_ENDPOINT=http://host.docker.internal:8888
SEAWEED_S3_ENDPOINT=http://host.docker.internal:8333
SEAWEED_ACCESS_KEY=
SEAWEED_SECRET_KEY=
SEAWEED_BUCKET=astramolecula
PRESIGNED_URL_EXPIRES=3600

# ── Task Processing ─────────────────────────────────────────
# How often (seconds) to poll the database for pending tasks
TASK_QUERY_INTERVAL=180
# Maximum number of concurrent tasks
MAX_CONCURRENT_TASKS=2

# ── HighFold-C2C Defaults ───────────────────────────────────
# Path to C2C model checkpoint
C2C_CHECKPOINT_PATH=checkpoints/c2c_model.pt
# Path to colabfold_batch executable
COLABFOLD_BIN=colabfold_batch
# Default model and MSA settings
DEFAULT_MODEL_TYPE=alphafold2
DEFAULT_MSA_MODE=single_sequence
DEFAULT_NUM_MODELS=5
DEFAULT_SPAN_LEN=5
DEFAULT_NUM_SAMPLE=20
DEFAULT_TEMPERATURE=1.0
DEFAULT_TOP_P=0.9
DEFAULT_SEED=42

# ── File Paths ───────────────────────────────────────────────
RESOURCE_DIR=/tmp/highfold_c2c/resource
TEMP_DIR=/tmp/highfold_c2c
LOG_DIR=/tmp/highfold_c2c/logs
